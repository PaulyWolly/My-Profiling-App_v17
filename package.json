{
  "name": "angular17-signup-verify-mongodb",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 5000 --proxy-config proxy.conf.json",
    "prestart": "node scripts/generate-build-version.js",
    "start:server": "cd server && npm start",
    "start:server:prod": "cd server && npm run start:prod",
    "start:all": "concurrently -n \"FRONTEND,BACKEND\" -c \"green,blue\" \"npm run start\" \"npm run start:server\"",
    "build": "ng build",
    "prebuild": "node scripts/generate-build-version.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "clean": "rimraf node_modules && rimraf dist && rimraf .angular/cache",
    "backup": "node scripts/ENHANCED_BACKUP_ANGULAR_APP.js",
    "backup:run": "npm run backup"
  },
  "private": true,
  "engines": {
    "node": ">=18.19.0"
  },
  "dependencies": {
    "@angular/animations": "17.3.12",
    "@angular/cdk": "17.3.10",
    "@angular/common": "17.3.12",
    "@angular/compiler": "17.3.12",
    "@angular/core": "17.3.12",
    "@angular/forms": "17.3.12",
    "@angular/material": "17.3.10",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "17.3.12",
    "@angular/router": "17.3.12",
    "@auth0/angular-jwt": "^5.2.0",
    "@auth0/auth0-angular": "^2.3.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "busboy": "^1.6.0",
    "chalk": "^4.1.2",
    "concurrently": "^8.2.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.1",
    "emoji-picker-element": "^1.26.3",
    "multer": "^1.4.5-lts.2",
    "nodemon": "^3.1.10",
    "rootpath": "^0.1.2",
    "rxjs": "~7.5.0",
    "tslib": "^2.5.2",
    "zone.js": "~0.14.10"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "17.3.17",
    "@angular/cli": "17.3.17",
    "@angular/compiler-cli": "17.3.12",
    "@types/jasmine": "^4.3.2",
    "jasmine-core": "~4.5.0",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.0.0",
    "typescript": "~5.4.5"
  }
